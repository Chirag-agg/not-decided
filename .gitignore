# ===========================
# etgen — Root .gitignore
# ===========================

# ----- OS Files -----
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ----- IDE / Editor -----
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
venv/
.venv/
env/
.env
.env.*
*.pyo
pip-log.txt
pip-delete-this-directory.txt

# ----- Node / JavaScript -----
node_modules/
.next/
out/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- Build / Artifacts -----
*.tsbuildinfo
next-env.d.ts
coverage/
.vercel

# ----- Docker -----
docker-compose.override.yml

# ----- Misc -----
*.pem
*.log
